# ── Database (Supabase) ──────────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL (port 6543) for Prisma
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use the "Session" URL (port 5432) for migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Auth (NextAuth) ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Stripe (TEST MODE) ───────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Supabase Storage ─────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ── Email (Resend) ───────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="StreetMap <noreply@yourdomain.com>"
